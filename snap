set -o errexit
set -o nounset

main() {
    if test "${1}" != "install"; then
        printf "Error: Intercepted non-install command: snap %s\n" "$*" 1>&2
        exit 0
    fi

    local snap_name="${2}"
    if test -z "${snap_name}"; then
        printf "Error: No snap name specified.\n" 1>&2
        exit 1
    fi

    printf "Info: Intercepting: snap install %s\n" "${snap_name}"

    # Ensure extraction dependencies exist
    command -v unsquashfs >/dev/null 2>&1 || { apt-get update && apt-get install -y squashfs-tools; }
    command -v curl >/dev/null 2>&1 || { apt-get update && apt-get install -y curl; }
    command -v jq >/dev/null 2>&1 || { apt-get update && apt-get install -y jq; }

    download_and_extract "${snap_name}"
}

download_and_extract() {
    local snap_name="${1}"; shift
    local target_dir="/snap/${snap_name}"
    local current_dir="${target_dir}/current"
    local work_dir
    local download_url

    # Check if already installed
    if test -d "${current_dir}"; then
        printf "Info: %s is already extracted at %s\n" "${snap_name}" "${current_dir}"
        return 0
    fi

    work_dir=$(mktemp -d)
    cd "${work_dir}"

    printf "Info: Querying Snap Store API for %s...\n" "${snap_name}"
    # Query Ubuntu Snap Store v2 API for the download link
    download_url=$(curl -sH 'Snap-Device-Series: 16' "https://api.snapcraft.io/v2/snaps/info/${snap_name}" | \
        jq -r '.["channel-map"][] | select(.channel.risk=="stable" and .channel.track=="latest") | .download.url' | head -n 1)

    if test -z "${download_url}" || test "${download_url}" = "null"; then
        printf "Error: Could not find download URL for snap '%s'\n" "${snap_name}" 1>&2
        rm -rf "${work_dir}"
        return 1
    fi

    printf "Info: Downloading %s...\n" "${snap_name}"
    curl -sL "${download_url}" -o package.snap

    printf "Info: Extracting to %s...\n" "${current_dir}"
    mkdir -p "${target_dir}"
    unsquashfs -d "${current_dir}" package.snap

    # Cleanup temporary download
    cd /
    rm -rf "${work_dir}"

    printf "Info: Successfully stubbed %s into %s/current\n" "${snap_name}" "${current_dir}"
}

main "$@"
